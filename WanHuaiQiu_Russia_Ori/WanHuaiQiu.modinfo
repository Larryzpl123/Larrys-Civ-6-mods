      <File>Core/WHQ_FrontEnd.xml</File>
    </UpdateDatabase>
    <UpdateText id="WHQFrontEndText">
      <File>Core/WHQ_GameText.xml</File>
    </UpdateText>
  </FrontEndActions>
  <InGameActions>
    <UpdateDatabase id="WHQLeaders">
      <File>Core/WHQ_Leaders.xml</File>
    </UpdateDatabase>
    <UpdateDatabase id="WHQGameplay">
      <File>Core/WHQ_GameDefines.xml</File>
    </UpdateDatabase>
    <UpdateText id="WHQGameText">
      <File>Core/WHQ_GameText.xml</File>
    </UpdateText>
  </InGameActions>
