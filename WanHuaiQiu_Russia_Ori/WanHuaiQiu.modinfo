  <Properties>
    <Name>Wan Huai Qiu for Russia</Name>
    <Description>Adds Wan Huai Qiu as an alternate leader for Russia.</Description>
    <Authors>Larry</Authors>
    <CompatibleVersions>1.2,2.0</CompatibleVersions>
  </Properties>
  <Files>
    <File>Core/WHQ_FrontEnd.xml</File>
    <File>Core/WHQ_Leaders.xml</File>
    <File>Core/WHQ_GameDefines.xml</File>
    <File>Core/WHQ_GameText.xml</File>
  </Files>
  <FrontEndActions>
